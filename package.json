{
  "name": "llm-companion",
  "description": "A browser extension for LLM interaction with web pages",
  "license": "MIT",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test:watch": "vitest",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip -b chromium",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@preact/signals": "^2.8.2",
    "lucide-preact": "^1.0.0",
    "preact": "^10.29.0",
    "turndown": "7.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.1.37",
    "@types/jsdom": "^28.0.0",
    "@types/mozilla-readability": "^0.2.1",
    "@types/turndown": "^5.0.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wxt": "^0.20.19"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ],
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ]
  }
}
